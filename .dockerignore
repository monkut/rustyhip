# Mirror .gitignore + things that shouldn't ride along in a docker build context.
# Without this, `COPY . .` drags in gigabytes of target/ and pollutes the image.

# Rust build artifacts
target/
Cargo.lock.bak

# VCS + CI
.git/
.github/

# Editor / OS
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Env / secrets
.env
.env.*
!.env.example

# Test output
target/nextest/
test-reports/
junit.xml
*.profraw
*.profdata
cov/
lcov.info
coverage/

# Logs
*.log

# Local floci / sqlite state
data/
*.sqlite3
*.sqlite3-journal
*.sqlite3-wal
*.sqlite3-shm

# Claude / scratch
.claude/
CHECKPOINT.md
